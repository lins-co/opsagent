generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// OPS INTELLIGENCE TABLES (9)
// ============================================================

model FleetHealth {
  id              String   @id @default(uuid()) @db.Uuid
  vehicleId       String   @map("vehicle_id")
  packId          String?  @map("pack_id")
  date            DateTime @db.Date
  locationCity    String   @map("location_city")
  rideDurationMin Float?   @map("ride_duration_min")
  idleTimeMin     Float?   @map("idle_time_min")
  totalDistanceKm Float?   @map("total_distance_km")
  faultCodes      String[] @map("fault_codes")
  faultCount      Int      @default(0) @map("fault_count")
  usageHours      Float?   @map("usage_hours")
  ignitionCycles  Int?     @map("ignition_cycles")
  harshBrakingCnt Int?     @map("harsh_braking_count")
  firmwareVersion String?  @map("firmware_version")
  batchId         String?  @map("batch_id")
  ingestedAt      DateTime @default(now()) @map("ingested_at")

  @@unique([vehicleId, date])
  @@index([vehicleId, date(sort: Desc)])
  @@index([date(sort: Desc)])
  @@index([locationCity])
  @@map("fleet_health")
}

model BatteryRisk {
  id               String   @id @default(uuid()) @db.Uuid
  packId           String   @map("pack_id")
  vehicleId        String?  @map("vehicle_id")
  date             DateTime @db.Date
  firmwareVersion  String?  @map("firmware_version")
  chargeCycles     Int?     @map("charge_cycles")
  socSwing         Float?   @map("soc_swing")
  tempMaxC         Float?   @map("temp_max_c")
  tempSpikeCount   Int      @default(0) @map("temp_spike_count")
  dcirMohm         Float?   @map("dcir_mohm")
  cellImbalanceMv  Float?   @map("cell_imbalance_mv")
  sohPercent       Float?   @map("soh_percent")
  degradationSlope Float?   @map("degradation_slope")
  riskFlag         String   @default("none") @map("risk_flag")
  riskReason       String?  @map("risk_reason")
  abnormalAlert    Boolean  @default(false) @map("abnormal_alert")
  alertType        String?  @map("alert_type")
  predictedEolDate DateTime? @map("predicted_eol_date") @db.Date
  batchId          String?  @map("batch_id")
  locationCity     String?  @map("location_city")
  ingestedAt       DateTime @default(now()) @map("ingested_at")

  @@unique([packId, date])
  @@index([packId, date(sort: Desc)])
  @@index([batchId])
  @@index([firmwareVersion])
  @@map("battery_risk")
}

model Complaint {
  id                  String   @id @default(uuid()) @db.Uuid
  complaintId         String   @unique @map("complaint_id")
  vehicleId           String   @map("vehicle_id")
  packId              String?  @map("pack_id")
  timestamp           DateTime
  complaintType       String   @map("complaint_type")
  complaintCategory   String   @map("complaint_category")
  description         String?
  locationCity        String   @map("location_city")
  riderName           String?  @map("rider_name")
  operatorName        String?  @map("operator_name")
  resolutionStatus    String   @default("open") @map("resolution_status")
  resolutionTimeHours Float?   @map("resolution_time_hours")
  resolutionType      String?  @map("resolution_type")
  firmwareVersion     String?  @map("firmware_version")
  batchId             String?  @map("batch_id")
  ingestedAt          DateTime @default(now()) @map("ingested_at")

  serviceLogs ServiceLog[]

  @@index([vehicleId])
  @@index([packId])
  @@index([timestamp(sort: Desc)])
  @@index([complaintCategory])
  @@index([resolutionStatus])
  @@index([locationCity])
  @@map("complaints")
}

model ServiceLog {
  id                  String   @id @default(uuid()) @db.Uuid
  serviceId           String   @unique @map("service_id")
  vehicleId           String   @map("vehicle_id")
  packId              String?  @map("pack_id")
  timestamp           DateTime
  repairType          String   @map("repair_type")
  partsReplaced       String[] @map("parts_replaced")
  rootCauseTag        String   @map("root_cause_tag")
  rootCauseDetail     String?  @map("root_cause_detail")
  timeToResolveHours  Float    @map("time_to_resolve_hours")
  technicianName      String   @map("technician_name")
  firmwareVersion     String?  @map("firmware_version")
  batchId             String?  @map("batch_id")
  locationCity        String   @map("location_city")
  isRepeatRepair      Boolean  @default(false) @map("is_repeat_repair")
  relatedComplaintId  String?  @map("related_complaint_id")
  ingestedAt          DateTime @default(now()) @map("ingested_at")

  relatedComplaint Complaint? @relation(fields: [relatedComplaintId], references: [complaintId])

  @@index([vehicleId])
  @@index([rootCauseTag])
  @@index([timestamp(sort: Desc)])
  @@map("service_logs")
}

model FirmwareMap {
  id              String   @id @default(uuid()) @db.Uuid
  vehicleId       String   @map("vehicle_id")
  packId          String?  @map("pack_id")
  firmwareVersion String   @map("firmware_version")
  previousVersion String?  @map("previous_version")
  deployedDate    DateTime @map("deployed_date") @db.Date
  deployedBy      String?  @map("deployed_by")
  batchId         String?  @map("batch_id")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([vehicleId, deployedDate(sort: Desc)])
  @@index([firmwareVersion])
  @@index([batchId])
  @@map("firmware_map")
}

model VehiclePackMap {
  id        String    @id @default(uuid()) @db.Uuid
  vehicleId String    @map("vehicle_id")
  packId    String    @map("pack_id")
  batchId   String?   @map("batch_id")
  mappedFrom String   @map("mapped_from")
  active    Boolean   @default(true)
  validFrom DateTime  @map("valid_from") @db.Date
  validTo   DateTime? @map("valid_to") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([vehicleId])
  @@index([packId])
  @@map("vehicle_pack_map")
}

model AnomalyLog {
  id            String   @id @default(uuid()) @db.Uuid
  agentName     String   @map("agent_name")
  severity      String
  vehicleId     String?  @map("vehicle_id")
  packId        String?  @map("pack_id")
  batchId       String?  @map("batch_id")
  locationCity  String?  @map("location_city")
  anomalyType   String   @map("anomaly_type")
  description   String
  dataSnapshot  Json?    @map("data_snapshot")
  reportDate    DateTime @map("report_date") @db.Date
  acknowledged  Boolean  @default(false)
  acknowledgedBy String? @map("acknowledged_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([reportDate(sort: Desc)])
  @@index([agentName, reportDate(sort: Desc)])
  @@index([vehicleId])
  @@map("anomaly_log")
}

model OpsReport {
  id          String   @id @default(uuid()) @db.Uuid
  reportType  String   @map("report_type")
  reportDate  DateTime @map("report_date") @db.Date
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date
  content     String
  summary     String
  metrics     Json
  agentName   String   @map("agent_name")
  tokensUsed  Int?     @map("tokens_used")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([reportType, reportDate(sort: Desc)])
  @@map("ops_reports")
}

// ============================================================
// ENTERPRISE BACKBONE TABLES (11+)
// ============================================================

model OrgNode {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  parentId  String?   @map("parent_id") @db.Uuid
  level     Int       @default(0)
  locations String[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  parent   OrgNode?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children OrgNode[] @relation("OrgHierarchy")
  users    User[]

  @@index([parentId])
  @@map("org_nodes")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  permissions Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  users User[]

  @@map("roles")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  roleId       String    @map("role_id") @db.Uuid
  orgNodeId    String    @map("org_node_id") @db.Uuid
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  role            Role             @relation(fields: [roleId], references: [id])
  orgNode         OrgNode          @relation(fields: [orgNodeId], references: [id])
  auditLogs       AuditLog[]
  conversations   Conversation[]
  bookmarks       Bookmark[]
  alertRules      AlertRule[]
  scheduledReports ScheduledReport[]
  csvUploads      CsvUpload[]

  @@index([orgNodeId])
  @@map("users")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  resource  String?
  details   Json?
  ipAddress String?  @map("ip_address")
  channel   String?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Conversation {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  title      String?
  channel    String    @default("web")
  isArchived Boolean   @default(false) @map("is_archived")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  messages Message[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String
  content        String
  source         String?
  agentName      String?  @map("agent_name")
  tokensUsed     Int?     @map("tokens_used")
  latencyMs      Int?     @map("latency_ms")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  bookmarks    Bookmark[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Bookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("bookmarks")
}

model KpiDefinition {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @unique
  displayName       String   @map("display_name")
  description       String?
  formula           String
  unit              String   @default("%")
  targetValue       Float?   @map("target_value")
  warningThreshold  Float?   @map("warning_threshold")
  criticalThreshold Float?   @map("critical_threshold")
  scope             String   @default("location")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  snapshots KpiSnapshot[]

  @@map("kpi_definitions")
}

model KpiSnapshot {
  id         String   @id @default(uuid()) @db.Uuid
  kpiId      String   @map("kpi_id") @db.Uuid
  orgNodeId  String?  @map("org_node_id") @db.Uuid
  location   String?
  value      Float
  period     String
  periodType String   @default("daily") @map("period_type")
  computedAt DateTime @default(now()) @map("computed_at")

  kpi KpiDefinition @relation(fields: [kpiId], references: [id])

  @@index([kpiId, periodType, period(sort: Desc)])
  @@index([orgNodeId, period(sort: Desc)])
  @@map("kpi_snapshots")
}

model AlertRule {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  name          String
  conditionType String    @map("condition_type")
  condition     Json
  channel       String    @default("web")
  isActive      Boolean   @default(true) @map("is_active")
  lastTriggered DateTime? @map("last_triggered")
  createdAt     DateTime  @default(now()) @map("created_at")

  user    User           @relation(fields: [userId], references: [id])
  history AlertHistory[]

  @@map("alert_rules")
}

model AlertHistory {
  id          String    @id @default(uuid()) @db.Uuid
  ruleId      String    @map("rule_id") @db.Uuid
  payload     Json
  delivered   Boolean   @default(false)
  deliveredAt DateTime? @map("delivered_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  rule AlertRule @relation(fields: [ruleId], references: [id])

  @@map("alert_history")
}

model QueryCache {
  id        String   @id @default(uuid()) @db.Uuid
  queryHash String   @map("query_hash")
  scopeHash String   @map("scope_hash")
  response  String
  source    String
  hitCount  Int      @default(0) @map("hit_count")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@unique([queryHash, scopeHash])
  @@map("query_cache")
}

// ============================================================
// PLATFORM TABLES (V3 additions)
// ============================================================

model ScheduledReport {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  name            String
  reportType      String    @map("report_type")
  prompt          String?
  dataScope       Json      @default("{}") @map("data_scope")
  scheduleCron    String    @map("schedule_cron")
  deliveryChannel String    @default("web") @map("delivery_channel")
  deliveryTarget  String?   @map("delivery_target")
  isActive        Boolean   @default(true) @map("is_active")
  lastRunAt       DateTime? @map("last_run_at")
  nextRunAt       DateTime? @map("next_run_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("scheduled_reports")
}

model CsvUpload {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  conversationId String?   @map("conversation_id") @db.Uuid
  fileName       String    @map("file_name")
  filePath       String    @map("file_path")
  fileSizeBytes  BigInt    @map("file_size_bytes")
  columnSchema   Json      @map("column_schema")
  rowCount       Int       @map("row_count")
  uploadedAt     DateTime  @default(now()) @map("uploaded_at")
  expiresAt      DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id])

  @@map("csv_uploads")
}

// ============================================================
// WHATSAPP MONITORING
// ============================================================

model WaMonitoredGroup {
  id          String   @id @default(uuid()) @db.Uuid
  chatId      String   @unique @map("chat_id")
  chatName    String   @map("chat_name")
  isGroup     Boolean  @default(true) @map("is_group")
  isActive    Boolean  @default(true) @map("is_active")
  addedBy     String   @map("added_by") @db.Uuid
  messageCount Int     @default(0) @map("message_count")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Per-group proactive settings
  proactiveEnabled Boolean @default(false) @map("proactive_enabled")

  messages WaMessage[]

  @@map("wa_monitored_groups")
}

model WaMessage {
  id          String   @id @default(uuid()) @db.Uuid
  groupId     String   @map("group_id") @db.Uuid
  chatId      String   @map("chat_id")
  senderId    String   @map("sender_id")
  senderName  String   @map("sender_name")
  body        String
  messageType String   @default("chat") @map("message_type")
  timestamp   DateTime
  createdAt   DateTime @default(now()) @map("created_at")

  // Extracted entities (populated at ingest time via regex)
  vehicleIds  String[] @default([]) @map("vehicle_ids")
  location    String?
  category    String?  // "complaint" | "deployment" | "payment" | "query" | "status" | "other"

  group WaMonitoredGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, timestamp(sort: Desc)])
  @@index([chatId, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
  @@index([category])
  @@map("wa_messages")
}

// ══════════════════════════════════════════════════════
// WhatsApp Insights — extracted patterns and recurring issues
// Populated by the pattern extraction cron.
// ══════════════════════════════════════════════════════
model WaInsight {
  id                String   @id @default(uuid()) @db.Uuid
  type              String   // "complaint" | "issue" | "escalation" | "resolution" | "alert"
  title             String
  summary           String
  severity          String   @default("medium") // "critical" | "high" | "medium" | "low"
  category          String?  // e.g. "battery", "charger", "vehicle", "payment"
  status            String   @default("open") // "open" | "in_progress" | "resolved"

  groupId           String?  @map("group_id") @db.Uuid
  groupName         String?  @map("group_name")
  vehicleIds        String[] @default([]) @map("vehicle_ids")
  location          String?
  reporterNames     String[] @default([]) @map("reporter_names")

  firstSeen         DateTime @map("first_seen")
  lastSeen          DateTime @map("last_seen")
  occurrenceCount   Int      @default(1) @map("occurrence_count")
  relatedMessageIds String[] @default([]) @map("related_message_ids") @db.Uuid

  resolvedAt        DateTime? @map("resolved_at")
  resolvedBy        String?   @map("resolved_by") @db.Uuid
  notes             String?

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([type, status])
  @@index([severity, status])
  @@index([category])
  @@index([lastSeen(sort: Desc)])
  @@index([occurrenceCount(sort: Desc)])
  @@map("wa_insights")
}

// ══════════════════════════════════════════════════════
// WhatsApp media files — images, docs, videos from groups
// Files stored on disk (or S3 later), metadata here.
// ══════════════════════════════════════════════════════
model WaMediaFile {
  id           String   @id @default(uuid()) @db.Uuid
  messageId    String?  @map("message_id") @db.Uuid  // Optional — message may not be persisted yet
  chatId       String   @map("chat_id")
  groupName    String?  @map("group_name")
  senderName   String?  @map("sender_name")
  mediaType    String   @map("media_type")  // "image" | "video" | "document" | "audio" | "sticker"
  mimeType     String?  @map("mime_type")
  fileName     String?  @map("file_name")
  filePath     String   @map("file_path")   // Path on disk (or S3 URL)
  fileSize     Int?     @map("file_size")
  caption      String?

  // Vision processing (populated on-demand)
  visionText   String?  @map("vision_text") // Claude Vision extracted text/description
  processedAt  DateTime? @map("processed_at")

  timestamp    DateTime  // Original message timestamp
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([chatId, timestamp(sort: Desc)])
  @@index([mediaType])
  @@map("wa_media_files")
}

// ══════════════════════════════════════════════════════
// App-level settings — feature flags and configuration
// ══════════════════════════════════════════════════════
model AppSetting {
  key       String   @id
  value     Json
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("app_settings")
}
